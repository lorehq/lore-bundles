#!/usr/bin/env bash
# Dev Discipline — Pre-Commit Hook
# Warns on potential discipline violations. Advisory by default.

WARNINGS=0
ERRORS=0

# Colors (if terminal supports them)
RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

warn() { echo -e "${YELLOW}⚠️  $1${NC}"; WARNINGS=$((WARNINGS + 1)); }
err()  { echo -e "${RED}❌ $1${NC}"; ERRORS=$((ERRORS + 1)); }

is_int() { [[ "$1" =~ ^[0-9]+$ ]]; }

# Optional repo-level config
# shellcheck disable=SC1090
CONFIG_FILE="${DEV_DISCIPLINE_CONFIG_FILE:-.dev/discipline.env}"
if [ -f "$CONFIG_FILE" ]; then
  . "$CONFIG_FILE"
fi

WARN_FILE_COUNT_DEFAULT=10
LARGE_FILE_COUNT_DEFAULT=20
WARN_DIR_COUNT_DEFAULT=4
PLAN_REQUIRED_SOURCE_FILE_COUNT_DEFAULT=5
ARCHITECTURE_WARN_SOURCE_FILE_COUNT_DEFAULT=8
ARCHITECTURE_WARN_DIR_COUNT_DEFAULT=3

WARN_FILE_COUNT="${DEV_DISCIPLINE_WARN_FILE_COUNT:-$WARN_FILE_COUNT_DEFAULT}"
LARGE_FILE_COUNT="${DEV_DISCIPLINE_LARGE_FILE_COUNT:-$LARGE_FILE_COUNT_DEFAULT}"
WARN_DIR_COUNT="${DEV_DISCIPLINE_WARN_DIR_COUNT:-$WARN_DIR_COUNT_DEFAULT}"
PLAN_REQUIRED_SOURCE_FILE_COUNT="${DEV_DISCIPLINE_PLAN_REQUIRED_SOURCE_FILE_COUNT:-$PLAN_REQUIRED_SOURCE_FILE_COUNT_DEFAULT}"
ARCHITECTURE_WARN_SOURCE_FILE_COUNT="${DEV_DISCIPLINE_ARCHITECTURE_WARN_SOURCE_FILE_COUNT:-$ARCHITECTURE_WARN_SOURCE_FILE_COUNT_DEFAULT}"
ARCHITECTURE_WARN_DIR_COUNT="${DEV_DISCIPLINE_ARCHITECTURE_WARN_DIR_COUNT:-$ARCHITECTURE_WARN_DIR_COUNT_DEFAULT}"

for numeric in WARN_FILE_COUNT LARGE_FILE_COUNT WARN_DIR_COUNT PLAN_REQUIRED_SOURCE_FILE_COUNT ARCHITECTURE_WARN_SOURCE_FILE_COUNT ARCHITECTURE_WARN_DIR_COUNT; do
  value="${!numeric}"
  if ! is_int "$value"; then
    warn "Invalid numeric value for $numeric ('$value'). Falling back to defaults."
    case "$numeric" in
      WARN_FILE_COUNT) WARN_FILE_COUNT="$WARN_FILE_COUNT_DEFAULT" ;;
      LARGE_FILE_COUNT) LARGE_FILE_COUNT="$LARGE_FILE_COUNT_DEFAULT" ;;
      WARN_DIR_COUNT) WARN_DIR_COUNT="$WARN_DIR_COUNT_DEFAULT" ;;
      PLAN_REQUIRED_SOURCE_FILE_COUNT) PLAN_REQUIRED_SOURCE_FILE_COUNT="$PLAN_REQUIRED_SOURCE_FILE_COUNT_DEFAULT" ;;
      ARCHITECTURE_WARN_SOURCE_FILE_COUNT) ARCHITECTURE_WARN_SOURCE_FILE_COUNT="$ARCHITECTURE_WARN_SOURCE_FILE_COUNT_DEFAULT" ;;
      ARCHITECTURE_WARN_DIR_COUNT) ARCHITECTURE_WARN_DIR_COUNT="$ARCHITECTURE_WARN_DIR_COUNT_DEFAULT" ;;
    esac
  fi
done

# --- 1. Large commit check ---
FILE_COUNT=$(git diff --cached --name-only | wc -l | tr -d ' ')
if [ "$FILE_COUNT" -gt "$LARGE_FILE_COUNT" ]; then
  warn "Large commit: $FILE_COUNT files staged. Consider splitting into smaller commits."
elif [ "$FILE_COUNT" -gt "$WARN_FILE_COUNT" ]; then
  warn "$FILE_COUNT files staged. Is this really one concern?"
fi

# --- 2. Multi-module check ---
DIR_COUNT=$(git diff --cached --name-only | cut -d'/' -f1 | sort -u | wc -l | tr -d ' ')
if [ "$DIR_COUNT" -gt "$WARN_DIR_COUNT" ]; then
  warn "Changes span $DIR_COUNT top-level directories. Might be multiple concerns."
fi

# --- 3. Source without tests ---
SRC_CHANGED=$(git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx|py|rs|go|rb|java|swift|kt)$' | grep -Ev '(test|spec|_test|\.test\.|\.spec\.)' | head -1)
TEST_CHANGED=$(git diff --cached --name-only | grep -Ei '(test|spec|_test)' | head -1)
if [ -n "$SRC_CHANGED" ] && [ -z "$TEST_CHANGED" ]; then
  warn "Source files changed but no test files included. If this is a behavioral change, add tests."
fi

# --- 4. ExecPlan enforcement (Codex execution plans) ---
SOURCE_FILE_COUNT=$(git diff --cached --name-only | grep -E '\.(ts|tsx|js|jsx|py|rs|go|rb|java|swift|kt|m|mm|c|cc|cpp|h)$' | grep -Ev '(test|spec|_test|\.test\.|\.spec\.)' | wc -l | tr -d ' ')
PLAN_FILE_COUNT=$(git diff --cached --name-only | grep -E '^docs/plans/active/.*\.md$' | grep -Ev '^docs/plans/active/(README|plan-template)\.md$' | wc -l | tr -d ' ')

if [ "$SOURCE_FILE_COUNT" -gt 0 ] && [ ! -f ".agent/PLANS.md" ]; then
  warn "Missing .agent/PLANS.md. Add it to define your execution-plan operating contract."
fi

if [ "$SOURCE_FILE_COUNT" -ge "$PLAN_REQUIRED_SOURCE_FILE_COUNT" ] && [ "$PLAN_FILE_COUNT" -eq 0 ]; then
  # Derive plan name from branch
  BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "main")
  case "$BRANCH" in
    main|master|develop|HEAD)
      PLAN_NAME="plan-$(date +%Y-%m-%d)"
      ;;
    *)
      # Strip prefix (feat/, fix/, etc.) and use the rest
      PLAN_NAME=$(echo "$BRANCH" | sed 's|^[a-z]*/||')
      ;;
  esac
  PLAN_PATH="docs/plans/active/${PLAN_NAME}.md"

  # Find plan template
  PLAN_TEMPLATE=""
  for candidate in \
    "docs/plans/active/plan-template.md" \
    "skills/planner/templates/exec-plan.md" \
    ".agents/skills/planner/templates/exec-plan.md" \
    "$HOME/.agents/skills/planner/templates/exec-plan.md"; do
    if [ -f "$candidate" ]; then
      PLAN_TEMPLATE="$candidate"
      break
    fi
  done

  if [ -f "$PLAN_PATH" ]; then
    # Plan exists but wasn't staged
    err "Significant source change ($SOURCE_FILE_COUNT files) requires an execution plan update. Update and stage existing plan: $PLAN_PATH"
  elif [ -n "$PLAN_TEMPLATE" ]; then
    # Scaffold from template
    mkdir -p "$(dirname "$PLAN_PATH")"
    cp "$PLAN_TEMPLATE" "$PLAN_PATH"
    err "Significant source change ($SOURCE_FILE_COUNT files) requires an execution plan update (docs/plans/active/*.md)."
    echo "   Scaffolded $PLAN_PATH from template."
    echo "   Fill in the required sections, stage it, and re-commit."
  else
    err "Significant source change ($SOURCE_FILE_COUNT files) requires an execution plan update (docs/plans/active/*.md)."
  fi
elif [ "$SOURCE_FILE_COUNT" -gt 0 ] && [ "$PLAN_FILE_COUNT" -eq 0 ]; then
  warn "Source files changed without an execution plan update. For non-trivial work, update docs/plans/active/."
fi

ARCHITECTURE_CHANGED=$(git diff --cached --name-only | grep -cE '^ARCHITECTURE\.md$' || true)
if [ "$SOURCE_FILE_COUNT" -ge "$ARCHITECTURE_WARN_SOURCE_FILE_COUNT" ] && [ "$DIR_COUNT" -ge "$ARCHITECTURE_WARN_DIR_COUNT" ] && [ "$ARCHITECTURE_CHANGED" -eq 0 ]; then
  warn "Broad source changes detected without ARCHITECTURE.md update. If boundaries/invariants changed, update architecture map."
fi

PLAN_FILES=$(git diff --cached --name-only | grep -E '^docs/plans/active/.*\.md$' | grep -Ev '^docs/plans/active/(README|plan-template)\.md$' || true)
if [ -n "$PLAN_FILES" ]; then
  PLAN_VALIDATOR=""
  for candidate in \
    "skills/planner/scripts/validate-plan.sh" \
    ".agents/skills/planner/scripts/validate-plan.sh" \
    "$HOME/.agents/skills/planner/scripts/validate-plan.sh"; do
    if [ -x "$candidate" ]; then
      PLAN_VALIDATOR="$candidate"
      break
    fi
  done

  if [ -z "$PLAN_VALIDATOR" ]; then
    warn "planner validator not found; cannot fully validate changed execution plans."
  else
    if ! "$PLAN_VALIDATOR" $PLAN_FILES; then
      err "Execution plan validation failed. Fix plan issues above."
    fi
  fi
fi

# --- 5. Debug artifact check (per-file, language-aware) ---
STAGED_FILES=$(git diff --cached --name-only)

# JavaScript/TypeScript: console.log, debugger
JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|mjs|cjs)$' || true)
if [ -n "$JS_FILES" ]; then
  for f in $JS_FILES; do
    if git diff --cached -U0 -- "$f" | grep -E '^\+' | grep -Ev '^\+\+\+' | grep -qE '(console\.log|debugger)'; then
      err "Debug statement in $f (console.log or debugger)"
    fi
  done
fi

# Python: breakpoint(), pdb
PY_FILES=$(echo "$STAGED_FILES" | grep -E '\.py$' || true)
if [ -n "$PY_FILES" ]; then
  for f in $PY_FILES; do
    if git diff --cached -U0 -- "$f" | grep -E '^\+' | grep -Ev '^\+\+\+' | grep -qE '(breakpoint\(\)|pdb\.set_trace\(\)|import pdb)'; then
      err "Debug statement in $f (breakpoint/pdb)"
    fi
  done
fi

# Ruby: binding.pry
RB_FILES=$(echo "$STAGED_FILES" | grep -E '\.rb$' || true)
if [ -n "$RB_FILES" ]; then
  for f in $RB_FILES; do
    if git diff --cached -U0 -- "$f" | grep -E '^\+' | grep -Ev '^\+\+\+' | grep -qE 'binding\.pry'; then
      err "Debug statement in $f (binding.pry)"
    fi
  done
fi

# --- 6. Conflict marker check ---
if git diff --cached | grep -qE '^(\+<<<<<<< |^\+=======$|^\+>>>>>>> )'; then
  err "Merge conflict markers found in staged changes."
fi

# --- Summary ---
if [ "$WARNINGS" -gt 0 ] || [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo "Dev Discipline: $WARNINGS warning(s), $ERRORS error(s)"
fi

if [ "$ERRORS" -gt 0 ]; then
  echo "Commit blocked. Fix errors above."
  exit 1
fi

exit 0
