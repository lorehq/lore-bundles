# Optional dev-discipline hook configuration.
# Copy to .dev/discipline.env and adjust thresholds as needed.

# Warn when staged file count exceeds this value.
DEV_DISCIPLINE_WARN_FILE_COUNT=10

# Escalated large-commit warning threshold.
DEV_DISCIPLINE_LARGE_FILE_COUNT=20

# Warn when top-level directory count exceeds this value.
DEV_DISCIPLINE_WARN_DIR_COUNT=4

# Require plan update error when staged source file count reaches this threshold.
DEV_DISCIPLINE_PLAN_REQUIRED_SOURCE_FILE_COUNT=5

# Warn when broad source changes likely require architecture doc updates.
DEV_DISCIPLINE_ARCHITECTURE_WARN_SOURCE_FILE_COUNT=8
DEV_DISCIPLINE_ARCHITECTURE_WARN_DIR_COUNT=3
