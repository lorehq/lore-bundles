#!/usr/bin/env bash
# Dev Discipline — Commit Message Hook
# Enforces conventional commit format with a why: line.

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

# Skip merge commits
if echo "$MSG" | head -1 | grep -qE '^Merge '; then
  exit 0
fi

# Skip fixup/squash commits
if echo "$MSG" | head -1 | grep -qE '^(fixup|squash)! '; then
  exit 0
fi

ERRORS=0

# --- 1. Conventional commit format ---
FIRST_LINE=$(echo "$MSG" | head -1)
if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|refactor|test|docs|chore|style|perf|ci|build|revert)(\(.+\))?: .+'; then
  echo -e "${RED}❌ Commit message doesn't follow conventional format.${NC}"
  echo "   Expected: type(scope): description"
  echo "   Types: feat, fix, refactor, test, docs, chore, style, perf, ci, build, revert"
  echo "   Got: $FIRST_LINE"
  ERRORS=$((ERRORS + 1))
fi

# --- 2. Subject line length ---
SUBJECT_LEN=${#FIRST_LINE}
if [ "$SUBJECT_LEN" -gt 72 ]; then
  echo -e "${YELLOW}⚠️  Subject line is $SUBJECT_LEN chars (aim for ≤72).${NC}"
fi

# --- 3. Why line required (lowercase only) ---
if ! echo "$MSG" | grep -qE '^why: .+'; then
  echo -e "${RED}❌ Missing 'why:' line in commit message.${NC}"
  echo "   Add a line starting with 'why:' (lowercase) explaining the motivation."
  echo ""
  echo "   Example:"
  echo "   feat(auth): add rate limiting to login endpoint"
  echo ""
  echo "   why: brute-force attacks were hitting 100k attempts/day"
  ERRORS=$((ERRORS + 1))
fi

# --- 4. Why line quality ---
WHY_LINE=$(echo "$MSG" | grep -E '^why: .+' | head -1)
if [ -n "$WHY_LINE" ]; then
  WHY_BODY="${WHY_LINE#why: }"
  WHY_LEN=${#WHY_BODY}

  # Minimum length
  if [ "$WHY_LEN" -lt 10 ]; then
    echo -e "${RED}❌ why: line is too short ($WHY_LEN chars, minimum 10).${NC}"
    echo "   The why: should explain motivation, not just restate the change."
    ERRORS=$((ERRORS + 1))
  fi

  # No parrot — why body can't match the subject description
  SUBJECT_DESC=$(echo "$FIRST_LINE" | sed 's/^[a-z]*\(([^)]*)\)\{0,1\}: //')
  SUBJECT_LOWER=$(echo "$SUBJECT_DESC" | tr '[:upper:]' '[:lower:]')
  WHY_LOWER=$(echo "$WHY_BODY" | tr '[:upper:]' '[:lower:]')
  if [ "$WHY_LOWER" = "$SUBJECT_LOWER" ]; then
    echo -e "${RED}❌ why: line restates the commit subject. Explain the motivation, not the change.${NC}"
    ERRORS=$((ERRORS + 1))
  fi

  # No filler phrases
  case "$WHY_LOWER" in
    "because it was needed"|"it needed to change"|"needed"|"update"|"fix"|"changes"|"necessary change"|"required")
      echo -e "${RED}❌ why: line uses a filler phrase. Be specific about the motivation.${NC}"
      ERRORS=$((ERRORS + 1))
      ;;
  esac
fi

if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo "Commit blocked. Fix your commit message."
  exit 1
fi

exit 0
